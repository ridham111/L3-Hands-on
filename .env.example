# ============================================================================
# Onboarding Brain - configuration. Copy to ".env" and fill in.
# ============================================================================

# ── Backend: claude_sdk (the only backend) ──────────────────────────────────
# Cortex runs on the Claude Agent SDK (claude-agent-sdk): the SDK runs the tool-use
# loop and the app supplies its 9 code-aware tools as an in-process MCP server.
#
# Runs on a Claude Pro/Max SUBSCRIPTION via OAuth — NOT a billed API key.
# One-time setup, pick ONE:
#   a) Long-lived token (best for servers/CI):  claude setup-token
#      then set CLAUDE_CODE_OAUTH_TOKEN below.
#   b) Interactive login on this machine:        claude   (creds in ~/.claude)
# IMPORTANT: ANTHROPIC_API_KEY must be UNSET, or it takes precedence and BILLS the
# API. (Set ONBOARDING_CLAUDE_SDK_ALLOW_API_KEY=1 only if you intend to use a key.)
ONBOARDING_LLM_BACKEND=claude_sdk
CLAUDE_CODE_OAUTH_TOKEN=
# Leave blank to use the subscription's default model (recommended — it's the
# strongest and, in our A/B, most tool-efficient choice).
CLAUDE_SDK_MODEL=

# Generation controls
ONBOARDING_TEMPERATURE=0.1
ONBOARDING_MAX_TOKENS=6000
ONBOARDING_REQUEST_TIMEOUT_S=240
ONBOARDING_MAX_RETRIES=2

# HTTP API access controls
ONBOARDING_API_KEYS=dev-local-key       # comma-separated; blank disables auth
ONBOARDING_MAX_REQUEST_BYTES=16384
ONBOARDING_RATE_LIMIT_PER_MIN=60

# Safety: only allow reading repos under these roots (comma-separated abs paths).
# Blank = allow any path (local dev only).
ONBOARDING_ALLOWED_ROOTS=

# Observability
ONBOARDING_LOG_LEVEL=INFO
ONBOARDING_TRACE_FILE=trace.json

# TLS: verify against OS trust store (handles corporate proxies). 1 = disable.
ONBOARDING_DISABLE_TRUSTSTORE=0
