# ============================================================================
# Onboarding Brain - configuration. Copy to ".env" and fill in.
# ============================================================================

# Model backend: claude | groq | openrouter
#  claude      -> Anthropic Claude via `claude auth` OAuth (no API key needed)
#  groq        -> Groq free tier (set GROQ_API_KEY)  https://console.groq.com/keys
#  openrouter  -> OpenRouter (set OPENROUTER_API_KEY) https://openrouter.ai/keys
ONBOARDING_LLM_BACKEND=claude

# Claude model (used when ONBOARDING_LLM_BACKEND=claude). No API key needed —
# authenticate once with: claude auth
CLAUDE_MODEL=claude-opus-4-8

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=

# Generation controls
ONBOARDING_TEMPERATURE=0.1
ONBOARDING_MAX_TOKENS=1800
ONBOARDING_REQUEST_TIMEOUT_S=45
ONBOARDING_MAX_RETRIES=2

# HTTP API access controls
ONBOARDING_API_KEYS=dev-local-key       # comma-separated; blank disables auth
ONBOARDING_MAX_REQUEST_BYTES=16384
ONBOARDING_RATE_LIMIT_PER_MIN=60

# Safety: only allow reading repos under these roots (comma-separated abs paths).
# Blank = allow any path (local dev only).
ONBOARDING_ALLOWED_ROOTS=

# Observability
ONBOARDING_LOG_LEVEL=INFO
ONBOARDING_TRACE_FILE=trace.json

# TLS: verify against OS trust store (handles corporate proxies). 1 = disable.
ONBOARDING_DISABLE_TRUSTSTORE=0
